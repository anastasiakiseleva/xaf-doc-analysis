#!/usr/bin/env python
"""
Find API documentation that should be tagged with "Deployment"
"""
import pandas as pd
import re

# Load data
print("📚 Loading API documentation...")
concepts = pd.read_parquet('outputs/doc_concepts.parquet')
inventory = pd.read_parquet('outputs/topics_inventory.parquet')
kept = concepts[concepts["kept"] == True]

# Get only API docs
api_docs = kept[kept["is_api"] == True]

print(f"✅ Total API documents: {len(api_docs)}\n")

# Search for deployment-related keywords in API docs
deployment_keywords = [
    "deploy", "deployment", "configuration", "connectionstring", 
    "appsettings", "startup", "applicationbuilder", "hosting",
    "iis", "azure", "docker", "publish"
]

print("🔍 Searching for deployment-related API documentation...")
print("="*70)

candidates = []

for _, row in api_docs.iterrows():
    doc_id = row["doc_id"]
    
    # Check if doc_id contains deployment keywords
    doc_id_lower = doc_id.lower()
    matched_keywords = [kw for kw in deployment_keywords if kw in doc_id_lower]
    
    if matched_keywords:
        # Get document content
        doc_rows = inventory[inventory["doc_id"] == doc_id]
        if not doc_rows.empty:
            doc = doc_rows.iloc[0]
            
            # Get current concepts
            current_concepts = row.get("concepts", [])
            if current_concepts is not None and hasattr(current_concepts, '__iter__'):
                current_concepts = list(current_concepts)
            else:
                current_concepts = []
            
            has_deployment = "Deployment" in current_concepts
            
            candidates.append({
                'doc_id': doc_id,
                'keywords': matched_keywords,
                'has_deployment_tag': has_deployment,
                'current_concepts': current_concepts[:5]  # First 5 concepts
            })

# Sort by number of matched keywords
candidates_df = pd.DataFrame(candidates)
candidates_df['keyword_count'] = candidates_df['keywords'].apply(len)
candidates_df = candidates_df.sort_values('keyword_count', ascending=False)

print(f"\n📊 Found {len(candidates_df)} API documents with deployment-related keywords\n")
print(f"Already tagged with Deployment: {candidates_df['has_deployment_tag'].sum()}")
print(f"Missing Deployment tag: {(~candidates_df['has_deployment_tag']).sum()}\n")

print("Top 20 API docs that should probably have 'Deployment' tag:")
print("="*70)

for i, row in candidates_df[~candidates_df['has_deployment_tag']].head(20).iterrows():
    print(f"\n{row['doc_id']}")
    print(f"   Keywords matched: {', '.join(row['keywords'])}")
    print(f"   Current concepts: {', '.join(row['current_concepts']) if row['current_concepts'] else 'None'}")

print("\n" + "="*70)
print("💡 RECOMMENDATION:")
print("="*70)
print("""
These API documents contain deployment-related terms but aren't tagged
with the 'Deployment' concept. Consider:

1. Review the API docs listed above
2. Add 'Deployment' concept tags where appropriate
3. Re-run concept extraction (script 03_extract_concepts.py)
4. Re-run semantic pairing to create cross-corpus links

This should significantly improve the Deployment concept connectivity!
""")
